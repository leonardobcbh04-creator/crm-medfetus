# Ambiente de producao
NODE_ENV=production

# Banco de dados local SQLite
# Ajuste para um caminho persistente no servidor.
DATABASE_URL=C:/medfetus/data/clinic.sqlite
CORS_ALLOWED_ORIGINS=https://SEU-FRONTEND.onrender.com
RUN_BACKGROUND_WORKERS_IN_API=true

# Integracao com Shosp
# Em producao real, o ideal e deixar o mock desligado.
# Credenciais sensiveis devem existir apenas como variaveis de ambiente do servidor.
SHOSP_USE_MOCK=false
# Em producao, mantenha desligado para nao popular pacientes ficticios no mock.
SHOSP_MOCK_FIXTURES=false
SHOSP_API_URL=https://api.shosp.seudominio.com
SHOSP_API_TOKEN=
SHOSP_API_KEY=preencher_chave_real
SHOSP_ACCOUNT_ID=preencher_conta_real
SHOSP_USERNAME=
SHOSP_PASSWORD=
SHOSP_TIMEOUT_MS=15000

# Intervalo da sincronizacao periodica em milissegundos.
# Exemplo abaixo: 5 minutos.
SHOSP_SYNC_INTERVAL=300000

# Endpoints da API do Shosp
SHOSP_PATIENTS_PATH=/patients
SHOSP_ATTENDANCES_PATH=/attendances
SHOSP_EXAMS_PATH=/exams
SHOSP_RETRY_ATTEMPTS=3
SHOSP_RETRY_DELAY_MS=1500

# Politica de retencao de logs
AUDIT_LOG_RETENTION_DAYS=365
SYNC_LOG_RETENTION_DAYS=90
MESSAGE_LOG_RETENTION_DAYS=30
LOG_RETENTION_CLEANUP_INTERVAL_HOURS=24

# Compatibilidade com configuracoes antigas do projeto
SHOSP_API_BASE_URL=
SHOSP_COMPANY_ID=

# Frontend
VITE_API_BASE_URL=https://SEU-BACKEND.onrender.com/api
