# Ambiente
NODE_ENV=development
DATABASE_URL=backend/data/clinic.sqlite
CORS_ALLOWED_ORIGINS=http://localhost:5173
RUN_BACKGROUND_WORKERS_IN_API=false

# Integracao com Shosp
# A integracao esta desligada por padrao nesta fase do produto.
# Credenciais sensiveis devem existir apenas neste arquivo/ambiente do backend, nunca no banco.
SHOSP_ENABLED=false
SHOSP_USE_MOCK=true
# Deixe false/vazio para manter o mock tecnico sem criar pacientes ficticios automaticamente.
SHOSP_MOCK_FIXTURES=false
SHOSP_API_URL=https://api.shosp.exemplo
SHOSP_API_TOKEN=
SHOSP_API_KEY=
SHOSP_ACCOUNT_ID=
SHOSP_USERNAME=
SHOSP_PASSWORD=
SHOSP_TIMEOUT_MS=15000
SHOSP_SYNC_INTERVAL=0
SHOSP_PATIENTS_PATH=/patients
SHOSP_ATTENDANCES_PATH=/attendances
SHOSP_EXAMS_PATH=/exams
SHOSP_RETRY_ATTEMPTS=3
SHOSP_RETRY_DELAY_MS=1500

# Politica de retencao de logs
AUDIT_LOG_RETENTION_DAYS=365
SYNC_LOG_RETENTION_DAYS=90
MESSAGE_LOG_RETENTION_DAYS=30
LOG_RETENTION_CLEANUP_INTERVAL_HOURS=24

# Compatibilidade com configuracoes antigas
SHOSP_API_BASE_URL=
SHOSP_COMPANY_ID=

# Frontend
VITE_API_URL=http://localhost:4000
